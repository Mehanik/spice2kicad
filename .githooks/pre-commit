#!/usr/bin/env bash
# Pre-commit hook: format + lint + test.
# Install with: git config core.hooksPath .githooks  (or run `just hooks`).
set -euo pipefail

echo "==> cargo fmt --check"
cargo fmt --all -- --check

echo "==> cargo clippy"
cargo clippy --workspace --all-targets -- -D warnings

echo "==> cargo test"
cargo test --workspace --quiet
